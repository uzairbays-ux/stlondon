<div class="kj-hero-banner" id="kj-hero-{{ section.id }}">
  <!-- Background Image/Video -->
  <div class="kj-hero-media">
    {%- if section.settings.image_desktop != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
        {%- endif -%}
        <img src="{{ section.settings.image_desktop | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" loading="eager" class="kj-hero-img">
      </picture>
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'kj-hero-placeholder' }}
    {%- endif -%}
    
    <!-- Overlay for text readability -->
    <div class="kj-hero-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; background-color: {{ section.settings.overlay_color }};"></div>
  </div>

  <!-- Content -->
  <div class="kj-hero-content-wrapper kj-hero-align-{{ section.settings.text_alignment }}">
    <div class="kj-hero-content" style="color: {{ section.settings.text_color }};">
      {%- if section.settings.heading != blank -%}
        <h1 class="kj-hero-heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="kj-hero-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      
      <div class="kj-hero-buttons">
        {%- if section.settings.button_1_text != blank and section.settings.button_1_link != blank -%}
          <a href="{{ section.settings.button_1_link }}" class="kj-btn kj-btn-primary" style="background-color: {{ section.settings.button_bg_color }}; color: {{ section.settings.button_text_color }}; border: 1px solid {{ section.settings.button_bg_color }};">
            {{ section.settings.button_1_text }}
          </a>
        {%- endif -%}
        
        {%- if section.settings.button_2_text != blank and section.settings.button_2_link != blank -%}
          <a href="{{ section.settings.button_2_link }}" class="kj-btn kj-btn-secondary" style="background-color: transparent; color: {{ section.settings.button_bg_color }}; border: 1px solid {{ section.settings.button_bg_color }};">
            {{ section.settings.button_2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .kj-hero-banner {
    position: relative;
    width: 100%;
    height: {{ section.settings.desktop_height }}vh;
    min-height: 400px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kj-hero-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .kj-hero-img, .kj-hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .kj-hero-placeholder {
    background-color: #f4f4f4;
    fill: #ccc;
  }

  .kj-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .kj-hero-content-wrapper {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 1200px;
    padding: 0 20px;
    display: flex;
  }

  .kj-hero-align-left { justify-content: flex-start; text-align: left; }
  .kj-hero-align-center { justify-content: center; text-align: center; }
  .kj-hero-align-right { justify-content: flex-end; text-align: right; }

  .kj-hero-content {
    max-width: 600px;
  }

  .kj-hero-heading {
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 15px 0;
    line-height: 1.1;
    color: inherit;
  }

  .kj-hero-subheading {
    font-size: clamp(14px, 2vw, 18px);
    margin: 0 0 30px 0;
    letter-spacing: 0.5px;
    color: inherit;
  }

  .kj-hero-buttons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }
  
  .kj-hero-align-center .kj-hero-buttons {
    justify-content: center;
  }
  .kj-hero-align-right .kj-hero-buttons {
    justify-content: flex-end;
  }

  .kj-btn {
    display: inline-block;
    padding: 14px 32px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .kj-btn-primary:hover {
    opacity: 0.8;
  }

  .kj-btn-secondary:hover {
    background-color: rgba(255,255,255,0.1) !important;
  }

  @media screen and (max-width: 767px) {
    .kj-hero-banner {
      height: {{ section.settings.mobile_height }}vh;
    }
    .kj-hero-buttons {
      flex-direction: column;
      width: 100%;
    }
    .kj-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "KJ Hero Banner",
  "tag": "section",
  "class": "kj-section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Background Image (Optional)"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop Height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile Height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 70
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEW COLLECTION"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop the latest arrivals."
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 Text"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "KJ Hero Banner"
    }
  ]
}
{% endschema %}
